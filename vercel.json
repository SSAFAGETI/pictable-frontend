{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://15.164.170.144:8000/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
